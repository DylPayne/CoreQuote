{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: CoreQuote",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/apps/streamlit/main.py",
                "--server.port",
                "8501"
            ],
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "API: FastAPI",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "env DATABASE_URL=postgresql://corequote:corequote_dev_password@localhost:5433/corequote_dev uv run uvicorn corequote_api.main:app --host 127.0.0.1 --port 8000"
        },
        {
            "name": "Web: Vite",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/web",
            "command": "npm run dev -- --host 127.0.0.1"
        }
    ],
    "compounds": [
        {
            "name": "CoreQuote: API + Web",
            "configurations": [
                "API: FastAPI",
                "Web: Vite"
            ],
            "stopAll": true
        }
    ]
}
