{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: CoreQuote",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/apps/streamlit/main.py",
                "--server.port",
                "8501"
            ],
            "justMyCode": true,
            "console": "integratedTerminal"
        }
    ]
}