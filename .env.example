# Local Postgres database used by Docker Compose.
COREQUOTE_POSTGRES_DB=corequote_dev
COREQUOTE_POSTGRES_USER=corequote
COREQUOTE_POSTGRES_PASSWORD=corequote_dev_password
COREQUOTE_POSTGRES_PORT=5433

# Future app/database layer should read this instead of the SQLite path.
DATABASE_URL=postgresql://corequote:corequote_dev_password@localhost:5433/corequote_dev

# Local frontend origins allowed to call the API with bearer auth.
COREQUOTE_CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):\d+$
